<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instrumen Pemantauan TKA 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // Konfigurasi Skema Warna Lembut (Soft Color Scheme)
        tailwind.config = {
