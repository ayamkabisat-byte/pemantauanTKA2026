                            { id: 'KAB-3.3', text: 'Apakah Daftar Nominasi Tetap (DNT) dan Kartu Peserta Ujian sudah dicetak dan didistribusikan ke sekolah-sekolah sebelum simulasi/gladi bersih dimulai?', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' }
                        ]
                    },
                    {
                        title: 'D. SDM dan Penanganan Kendala Teknis',
