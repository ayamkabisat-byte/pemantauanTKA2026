                            { id: 'KAB-2.2', text: 'Apakah seluruh penulis soal sudah menandatangani Pakta Integritas yang menjamin soal bebas plagiarisme dan tidak berafiliasi bimbel?', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
