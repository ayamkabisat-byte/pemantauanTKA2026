                            { id: 'KAB-1.1', text: 'Apakah Panitia Penyelenggara TKA Tingkat Kabupaten/Kota (Dinas/Kemenag) sudah dibentuk dan memiliki Surat Keputusan (SK) resmi?', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan / Tanggal SK:' },
                            { id: 'KAB-1.2', text: 'Apakah Dinas/Kemenag sudah melakukan sosialisasi kebijakan, jadwal, dan teknis pelaksanaan TKA kepada seluruh SD/MI dan SMP/MTs?', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan / Arsip Undangan:' },
