<body class="h-screen flex overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-white shadow-lg h-full flex flex-col z-10 transition-all duration-300 hidden md:flex absolute md:relative" id="sidebar">
        <div class="p-6 border-b flex items-start justify-center relative">
            <div class="flex flex-col items-center w-full">
                <!-- Logo Kemdikdasmen -->
                <img src="Logo Kemdikdasmen_bawah.png" alt="Logo Kemdikdasmen" class="w-32 mb-3 object-contain" onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/9/9c/Logo_of_Ministry_of_Education_and_Culture_of_Republic_of_Indonesia.svg'">
                
                <h1 class="text-sm font-bold text-gray-700 text-center uppercase tracking-wider">Pemantauan TKA</h1>
                <p class="text-[10px] text-gray-500 text-center mt-1 bg-gray-100 px-3 py-0.5 rounded-full font-medium">Tahun 2026</p>
            </div>
            <button id="closeSidebarBtn" class="md:hidden text-gray-400 hover:text-gray-700 absolute top-4 right-4">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <nav class="flex-1 overflow-y-auto py-4">
            <ul class="space-y-1" id="nav-menu">
                <!-- Navigation generated via JS -->
            </ul>
        </nav>
        <div class="p-4 border-t text-xs text-gray-400 text-center">
            Versi Final (Master Data)<br>2026
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-full overflow-hidden relative">
        <!-- Topbar -->
        <header class="bg-white shadow-sm border-b p-4 flex items-center justify-between z-0">
            <div class="flex items-center">
                <button id="menuBtn" class="mr-4 text-gray-600 hover:text-gray-900 md:hidden focus:outline-none">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <h2 class="text-xl font-semibold text-gray-800" id="header-title">Informasi Umum</h2>
            </div>
            <div class="flex items-center space-x-3 text-sm">
                <span class="bg-green-100 text-green-800 py-1 px-3 rounded-full font-medium flex items-center">
                    <i data-lucide="wifi" class="w-4 h-4 mr-1"></i> Online
                </span>
            </div>
        </header>

        <!-- Form Area -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 w-full max-w-5xl mx-auto">
            
            <form id="main-form" class="space-y-8 bg-white p-6 md:p-8 rounded-xl shadow-sm border">
                
                <!-- General Info (Always Visible) -->
                <div class="space-y-4 pb-6 border-b border-gray-200">
                    <h3 class="text-lg font-bold text-gray-800 flex items-center mb-4">
                        <i data-lucide="users" class="w-5 h-5 mr-2 text-blue-600"></i> Identitas Tim Pemantau & Sasaran
                    </h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Tim Petugas: Bisa 1 sampai 4 Orang -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:col-span-2 p-4 bg-gray-50 rounded-lg border border-gray-200">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Petugas 1 (Ketua Tim) *</label>
                                <input type="text" name="nama_petugas_1" required class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-blue-500 focus:border-blue-500 bg-white" placeholder="Nama Petugas 1">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Petugas 2 (Opsional)</label>
                                <input type="text" name="nama_petugas_2" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-blue-500 focus:border-blue-500 bg-white" placeholder="Nama Petugas 2">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Petugas 3 (Opsional)</label>
                                <input type="text" name="nama_petugas_3" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-blue-500 focus:border-blue-500 bg-white" placeholder="Nama Petugas 3">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Petugas 4 (Opsional)</label>
                                <input type="text" name="nama_petugas_4" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-blue-500 focus:border-blue-500 bg-white" placeholder="Nama Petugas 4">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Tanggal Pemantauan *</label>
                            <input type="date" name="tanggal" id="tanggal" required class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-blue-500 focus:border-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Provinsi *</label>
                            <input type="text" name="provinsi" required class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-blue-500 focus:border-blue-500" placeholder="Misal: Maluku Utara">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Kabupaten/Kota *</label>
                            <input type="text" name="kabkota" required class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-blue-500 focus:border-blue-500" placeholder="Misal: Kota Ternate">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Nama Instansi/Sekolah Sasaran *</label>
                            <input type="text" name="nama_sasaran" required class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-blue-500 focus:border-blue-500" placeholder="Misal: SMP Negeri 1 Ternate">
                        </div>
                    </div>
                </div>

                <!-- Dynamic Question Container -->
                <div id="questions-container" class="space-y-8">
                    <!-- Rendered via JS -->
                </div>

                <!-- Submit Button -->
                <div class="pt-6 border-t border-gray-200 flex justify-end">
                    <button type="submit" id="submitBtn" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 px-6 rounded-lg shadow-sm transition-colors flex items-center text-lg">
                        <i data-lucide="send" class="w-5 h-5 mr-2"></i> Kirim Jawaban ke Server
                    </button>
                </div>
            </form>
        </div>
    </main>

    <!-- Loading Modal -->
    <div id="loadingModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden z-50 flex items-center justify-center">
        <div class="bg-white rounded-xl p-8 flex flex-col items-center shadow-2xl">
            <div class="loader ease-linear rounded-full border-4 border-t-4 border-gray-200 h-12 w-12 mb-4"></div>
            <h2 class="text-xl font-semibold text-gray-800">Menyimpan Data...</h2>
            <p class="text-gray-500 mt-2 text-sm text-center">Mohon tunggu, sedang mengirim ke Google Sheets.</p>
        </div>
    </div>

    <!-- Success Modal -->
    <div id="successModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden z-50 flex items-center justify-center">
        <div class="bg-white rounded-xl p-8 max-w-sm w-full mx-4 shadow-2xl text-center transform transition-all">
            <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-green-100 mb-6">
                <i data-lucide="check" class="h-8 w-8 text-green-600"></i>
            </div>
            <h3 class="text-xl font-medium text-gray-900 mb-2">Berhasil Disimpan!</h3>
            <p class="text-gray-500 text-sm mb-6">Data instrumen telah berhasil dikirim ke database Google Sheets.</p>
            <button onclick="closeSuccessModal()" class="w-full inline-flex justify-center rounded-lg border border-transparent bg-blue-600 px-4 py-2 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 sm:text-sm">
                Lanjut Isi Instrumen
            </button>
        </div>
    </div>

    <script>
        // =========================================================================
        // URL WEB APP GOOGLE APPS SCRIPT (SUDAH TERHUBUNG)
        // =========================================================================
        const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycby52IF687IbilCPLMKHC9UTFJ3xyG9Qljyq8_xtc0B14V_Z4KwR0nnaOpKA9-OJXqG5/exec'; 

        lucide.createIcons();

        // Data Instrumen Lengkap Sesuai Dokumen V2
        const instruments = [
            {
                id: 'dinas',
                title: 'Dinas Kab/Kota',
                icon: 'building-2',
                sections: [
                    {
                        title: 'A. Tata Kelola dan Koordinasi',
