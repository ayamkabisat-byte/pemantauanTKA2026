                            { id: 'PGW-1', text: '(Pra) Hadir di lokasi tes minimal 45 menit sebelum ujian dimulai, dan masuk ruang pada 30 menit sebelum mulai.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PGW-2', text: '(Pra) Telah menandatangani dokumen Pakta Integritas sebelum mulai bertugas mengawasi.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PGW-3', text: '(Pelaksanaan) Membacakan Tata Tertib Ujian dengan suara lantang, jelas, dan ramah/mudah dimengerti anak.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PGW-4', text: '(Pelaksanaan) Memastikan peserta tidak membawa HP, smartwatch, kalkulator, atau kamera ke meja ujian.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PGW-5', text: '(Pelaksanaan) Mencocokkan wajah siswa yang duduk di depan layar dengan pasfoto di Kartu Peserta/Kartu Login.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PGW-6', text: '(Pelaksanaan) Memastikan siswa mengikuti Sesi Latihan (10 Menit) untuk mengenali tombol aplikasi sebelum ujian utama.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PGW-7', text: '(Pelaksanaan) Memberitahukan sandi Token ujian kepada peserta tepat saat sesi dimulai.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PGW-8', text: '(Pelaksanaan) Tidak memberikan bantuan jawaban, isyarat, atau petunjuk apa pun terkait konten soal.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PGW-9', text: '(Pelaksanaan) Menjaga ketenangan ruangan: tidak mengobrol, mematikan HP pribadi, dan tidak merokok.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' }
                        ]
                    },
                    {
                        title: 'B. PROKTOR',
                        questions: [
                            { id: 'PRK-1', text: '(Pra) Sudah menginstal dan mengatur aplikasi Proktor Browser atau VirtualBox & Exambrowser Admin dengan benar.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PRK-2', text: '(Pra Khusus Semi Daring) Berhasil melakukan "Sinkronisasi" data soal dari server pusat ke server lokal sebelum hari ujian.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PRK-3', text: '(Pelaksanaan) Merilis sandi Token ujian di aplikasi setiap kali sesi baru dimulai dan menyerahkannya kepada Pengawas.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PRK-4', text: '(Pelaksanaan) Selalu memantau status aktif peserta di layar aplikasi proktor (online, mengerjakan, selesai).', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PRK-5', text: '(Pelaksanaan) Cepat tanggap melakukan Reset Login jika komputer siswa tiba-tiba mati, error, atau logout paksa.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PRK-6', text: '(Pasca Khusus Semi Daring) Wajib mengunggah (upload) data jawaban peserta ke server pusat segera setelah sesi selesai.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'PRK-7', text: '(Kondisi Khusus) Paham alur meminta persetujuan Token Offline dari admin Kabupaten jika blank spot internet.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' }
                        ]
                    },
                    {
                        title: 'C. TEKNISI',
                        questions: [
                            { id: 'TKN-1', text: '(Pra) Memastikan jaringan kabel LAN, switch/hub, daya listrik (UPS), dan akses internet berfungsi stabil.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'TKN-2', text: '(Pra) Memastikan jalur kabel listrik di lab aman dan tidak berisiko tersandung oleh anak-anak.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
                            { id: 'TKN-3', text: '(Pelaksanaan) Selalu siaga di sekitar luar ruang ujian dan siap masuk cepat jika ada laporan kerusakan.', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' }
                        ]
                    }
                ]
            },
            {
                id: 'siswa',
                title: 'Wawancara Siswa',
                icon: 'messages-square',
                sections: [
                    {
                        title: 'A. Persiapan Sekolah',
                        questions: [
                            { id: 'SIS-1', text: 'Guru di sekolah sudah menjelaskan cara ikut ujian komputer, aturan yang tidak boleh dilakukan, dan lama waktu ujian.', type: 'radio', options: ['Sangat Setuju', 'Setuju', 'Tidak Setuju'], noteLabel: 'Catatan:' },
                            { id: 'SIS-2', text: 'Bulan lalu, saya sudah mengecek ejaan nama saya dan foto saya di kertas pendaftaran (DNS) dan semuanya benar.', type: 'radio', options: ['Sangat Setuju', 'Setuju', 'Tidak Setuju'], noteLabel: 'Catatan:' }
                        ]
                    },
                    {
                        title: 'B. Suasana Ujian dan Aplikasi',
                        questions: [
                            { id: 'SIS-3', text: 'Penjelasan dari Bapak/Ibu Pengawas di ruangan sangat jelas, ramah, dan mudah dipahami.', type: 'radio', options: ['Sangat Setuju', 'Setuju', 'Tidak Setuju'], noteLabel: 'Catatan:' },
                            { id: 'SIS-4', text: 'Latihan awal selama 10 menit tadi sangat membantu saya untuk mencoba pakai mouse dan belajar mengeklik jawaban.', type: 'radio', options: ['Sangat Setuju', 'Setuju', 'Tidak Setuju'], noteLabel: 'Catatan:' },
                            { id: 'SIS-5', text: 'Layar ujiannya gampang dipakai. Hurufnya mudah dibaca, gambarnya jelas, dan cara memilih jawaban tidak pusing.', type: 'radio', options: ['Sangat Setuju', 'Setuju', 'Tidak Setuju'], noteLabel: 'Catatan:' },
                            { id: 'SIS-6', text: 'Ukuran tulisan di layar komputer cukup besar dan mudah dibaca.', type: 'radio', options: ['Sangat Setuju', 'Setuju', 'Tidak Setuju'], noteLabel: 'Catatan:' },
                            { id: 'SIS-7', text: 'Suasana di ruangan ujian tadi sangat tenang, tidak berisik, jadi saya bisa berkonsentrasi mengerjakan soal.', type: 'radio', options: ['Sangat Setuju', 'Setuju', 'Tidak Setuju'], noteLabel: 'Catatan:' },
                            { id: 'SIS-8', text: 'Kalau komputer saya sempat error, guru yang jaga (Proktor) langsung cepat membantu memperbaikinya.', type: 'radio', options: ['Sangat Setuju', 'Setuju', 'Tidak Setuju'], noteLabel: 'Catatan:' }
                        ]
                    },
                    {
                        title: 'C. Pendapat Bebas',
                        questions: [
                            { id: 'SIS-9', text: 'Menurut kamu, bagian apa yang paling enak atau paling gampang dari ujian pakai komputer ini dibandingkan ujian pakai kertas?', type: 'text', noteLabel: 'Tambahan:' },
                            { id: 'SIS-10', text: 'Kalau boleh mengeluh, masalah apa yang paling mengganggu waktu kamu ujian hari ini?', type: 'text', noteLabel: 'Tambahan:' }
                        ]
                    }
                ]
            }
        ];

        let activeInstrumentId = 'dinas';

        // Initialize UI
        function init() {
            document.getElementById('tanggal').valueAsDate = new Date();
            renderNavigation();
            renderForm(activeInstrumentId);
            setupSidebarToggle();
            
            document.getElementById('main-form').addEventListener('submit', handleFormSubmit);
        }

        // Render Sidebar Navigation
        function renderNavigation() {
            const navMenu = document.getElementById('nav-menu');
            navMenu.innerHTML = '';

            instruments.forEach(inst => {
                const li = document.createElement('li');
                const isActive = inst.id === activeInstrumentId;
                
                li.innerHTML = `
                    <a href="#" onclick="switchTab('${inst.id}')" class="flex items-center px-6 py-3 text-sm transition-colors cursor-pointer ${isActive ? 'tab-active' : 'tab-inactive'}">
                        <i data-lucide="${inst.icon}" class="w-5 h-5 mr-3 ${isActive ? 'text-blue-600' : 'text-gray-400'}"></i>
                        ${inst.title}
                    </a>
                `;
                navMenu.appendChild(li);
            });
            lucide.createIcons();
        }

        // Switch Tab
        function switchTab(id) {
            activeInstrumentId = id;
            renderNavigation();
            renderForm(id);
            if (window.innerWidth < 768) {
                document.getElementById('sidebar').classList.add('hidden');
            }
        }

        // Render Form Questions
        function renderForm(instrumentId) {
            const container = document.getElementById('questions-container');
            const instrument = instruments.find(i => i.id === instrumentId);
            
            document.getElementById('header-title').innerText = `Instrumen: ${instrument.title}`;
            container.innerHTML = `<input type="hidden" id="kategori_instrumen" value="${instrument.title}">`;

            instrument.sections.forEach(section => {
                const sectionDiv = document.createElement('div');
                sectionDiv.className = 'bg-gray-50 p-5 rounded-lg border border-gray-200';
                
                let html = `<h4 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-200 text-lg">${section.title}</h4><div class="space-y-6">`;

                section.questions.forEach((q, index) => {
                    html += `<div class="bg-white p-4 rounded border shadow-sm">
                        <p class="text-sm font-medium text-gray-800 mb-3"><span class="bg-blue-100 text-blue-800 text-xs font-bold px-2 py-1 rounded mr-2">${q.id}</span>${q.text}</p>
                        <div class="flex flex-col md:flex-row md:items-start gap-4">
                    `;

                    // Answer Input
                    if (q.type === 'radio') {
                        html += `<div class="flex flex-col sm:flex-row flex-wrap gap-4 w-full md:w-1/2 pt-1">`;
                        q.options.forEach(opt => {
                            html += `
                                <label class="inline-flex items-center cursor-pointer bg-gray-50 border border-gray-200 px-3 py-2 rounded-md hover:bg-blue-50 transition-colors">
                                    <input type="radio" name="${q.id}_ans" value="${opt}" required class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500">
                                    <span class="ml-2 text-sm text-gray-700 whitespace-nowrap">${opt}</span>
                                </label>
                            `;
                        });
                        html += `</div>`;
                    } else if (q.type === 'text') {
                        html += `
                            <div class="w-full md:w-1/2">
                                <textarea name="${q.id}_ans" required class="w-full border border-gray-300 rounded-md p-2 text-sm focus:ring-blue-500 focus:border-blue-500" rows="3" placeholder="Tulis rincian jawaban di sini..."></textarea>
                            </div>
                        `;
                    }

                    // Note / Evidence Input
                    html += `
                            <div class="w-full md:w-1/2">
                                <label class="block text-xs font-medium text-gray-500 mb-1">${q.noteLabel}</label>
                                <textarea name="${q.id}_note" class="w-full border border-gray-300 rounded-md p-2 text-sm focus:ring-blue-500 focus:border-blue-500 bg-gray-50" rows="${q.type === 'text' ? '3' : '2'}" placeholder="Tambahkan temuan teknis/bukti (Opsional)..."></textarea>
                            </div>
                        </div>
                    </div>`;
                });

                html += `</div>`;
                sectionDiv.innerHTML = html;
                container.appendChild(sectionDiv);
            });
        }

        // Handle Sidebar Mobile Toggle
        function setupSidebarToggle() {
            const sidebar = document.getElementById('sidebar');
            document.getElementById('menuBtn').addEventListener('click', () => {
                sidebar.classList.remove('hidden');
                sidebar.classList.add('absolute', 'z-40');
            });
            document.getElementById('closeSidebarBtn').addEventListener('click', () => {
                sidebar.classList.add('hidden');
            });
        }

        // Handle Form Submission
        async function handleFormSubmit(e) {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            
            // Gabungkan Nama Tim Petugas Pemantau
            const petugasArray = [
                formData.get('nama_petugas_1'),
                formData.get('nama_petugas_2'),
                formData.get('nama_petugas_3'),
                formData.get('nama_petugas_4')
            ];
            const petugasGabungan = petugasArray.filter(name => name && name.trim() !== '').join(', ');

            const data = {
                timestamp: new Date().toISOString(),
                petugas: petugasGabungan,
                tanggal: formData.get('tanggal'),
                provinsi: formData.get('provinsi'),
                kabkota: formData.get('kabkota'),
                sasaran: formData.get('nama_sasaran'),
                kategori: document.getElementById('kategori_instrumen').value,
                jawaban: []
            };

            // Collect dynamic questions data
            const instrument = instruments.find(i => i.id === activeInstrumentId);
            instrument.sections.forEach(sec => {
                sec.questions.forEach(q => {
                    data.jawaban.push({
                        kode: q.id,
                        pertanyaan: q.text,
                        status: formData.get(`${q.id}_ans`) || '',
                        catatan: formData.get(`${q.id}_note`) || ''
                    });
                });
            });

            // Show Loading
            document.getElementById('loadingModal').classList.remove('hidden');

            try {
                const response = await fetch(SCRIPT_URL, {
                    method: 'POST',
                    mode: 'no-cors', 
                    cache: 'no-cache',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                // Jika sukses
                document.getElementById('loadingModal').classList.add('hidden');
                document.getElementById('successModal').classList.remove('hidden');
                
                // RESET PINTAR: Hanya mengosongkan jawaban, identitas tetap dipertahankan
                const dynamicInputs = document.querySelectorAll('#questions-container input[type="radio"], #questions-container textarea');
                dynamicInputs.forEach(input => {
                    if (input.type === 'radio') input.checked = false;
                    else input.value = '';
                });
                
            } catch (error) {
                console.error('Error!', error.message);
                document.getElementById('loadingModal').classList.add('hidden');
                alert("Terjadi kesalahan saat mengirim data. Pastikan koneksi internet stabil.");
            }
        }

        function closeSuccessModal() {
            document.getElementById('successModal').classList.add('hidden');
            window.scrollTo(0, 0);
        }

        // Initialize on load
        window.onload = init;
    </script>
</body>
</html>