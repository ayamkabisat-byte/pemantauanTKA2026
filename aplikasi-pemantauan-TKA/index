                            { id: 'KAB-4.1', text: 'Apakah SK Penugasan Pengawas Ruang sudah diterbitkan dengan sistem silang murni dan BUKAN guru mata pelajaran yang sedang diujikan?', type: 'radio', options: ['Ya', 'Tidak'], noteLabel: 'Catatan:' },
